#!/bin/bash -i

install() {
  CHECK_GIT_STATUS=0

  for file in $FILES; do
    local tname=$(target_name "$file")
    TARGET_FILE="$TARGET_DIR/$tname"
    if [ -L "$TARGET_FILE" ]; then
      if [ "$(readlink -f "$TARGET_FILE")" != "$(readlink -f "$file")" ]; then
        echo "Skipping '$TARGET_FILE': already a symlink to a different file"
      fi
    elif [ -f "$TARGET_FILE" ]; then
      cp "$TARGET_FILE" "$file"
      rm "$TARGET_FILE"
      ln -s "$file" "$TARGET_FILE"
      if [ -n "$(git status --porcelain "$file")" ]; then
        echo "Target file '$TARGET_FILE' already existed and differs against repo!"
        CHECK_GIT_STATUS=1
      fi
    else
      echo "Linking '$TARGET_FILE'"
      ln -s "$file" "$TARGET_FILE"
    fi
    config_add "$file" "$TARGET_FILE"
  done

  if [ $CHECK_GIT_STATUS -gt 0 ]; then
    echo ""
    git status
  fi
}
