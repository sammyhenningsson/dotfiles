#!/bin/bash -i

status() {
  echo "Linked:"
  find files/ -maxdepth 1 -type f -printf '%f\n' | while IFS= read -r name; do
    local linked_targets=""
    while IFS= read -r target; do
      [ -L "$target" ] && linked_targets="${linked_targets} ${target}"
    done < <(config_targets "$name")
    [ -n "$linked_targets" ] && echo "  $name ->${linked_targets}"
  done

  echo -e "\nUnlinked:"
  find files/ -maxdepth 1 -type f -printf '%f\n' | while IFS= read -r name; do
    local linked_targets=""
    while IFS= read -r target; do
      [ -L "$target" ] && linked_targets="${linked_targets} ${target}"
    done < <(config_targets "$name")
    [ -z "$linked_targets" ] && echo "  $name"
  done
}
